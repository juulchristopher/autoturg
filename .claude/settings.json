{
  "model": "claude-sonnet-4-6",
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/autoturg/.claude/hooks/check-usage.sh",
            "timeout": 5,
            "statusMessage": "Checking usage limit..."
          }
        ]
      }
    ],
    "Stop": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/autoturg/.claude/hooks/on-stop.sh",
            "timeout": 30,
            "statusMessage": "Saving session checkpoint..."
          }
        ]
      }
    ],
    "SessionStart": [
      {
        "matcher": "",
        "hooks": [
          {
            "type": "command",
            "command": "bash /home/user/autoturg/.claude/hooks/on-session-start.sh",
            "timeout": 30,
            "statusMessage": "Resuming session state..."
          }
        ]
      }
    ]
  }
}
